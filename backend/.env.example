# Copiar para .env e preencher. Nunca fazer commit do .env real.

ENVIRONMENT=development

# Chave da API Gemini (Google AI Studio) usada para gerar respostas das
# personas e para a moderação. Nível gratuito generoso — ver README.md para
# como obter a chave. Sem isto, o backend corre em modo de desenvolvimento
# com respostas simuladas (ver app/chat/router.py::_call_llm).
GEMINI_API_KEY=
LLM_MODEL=gemini-3.1-flash-lite
MODERATION_MODEL=gemini-3.1-flash-lite

# TTS / avatar (nível 2 do roadmap — avatar animado com lip-sync).
# Preencher quando o fornecedor for escolhido (D-ID / HeyGen / Simli).
TTS_PROVIDER=generic-tts
TTS_API_KEY=
AVATAR_PROVIDER=
AVATAR_API_KEY=

DATABASE_URL=sqlite:///./mentores.db
VECTOR_STORE_PATH=./data/vector_store

CORS_ORIGINS=["http://localhost:5173"]
